  "query": "\n                SELECT id, tenant_id, branch_id, product_id, quantity, min_quantity, updated_at as \"updated_at!\"\n                FROM inventory\n                WHERE branch_id = $1 AND quantity <= min_quantity\n                ORDER BY updated_at DESC\n                ",
