  "query": "\n            UPDATE customers\n            SET name = COALESCE($1, name),\n                phone = COALESCE($2, phone),\n                updated_at = NOW()\n            WHERE id = $3\n            RETURNING id, tenant_id, phone, name, points, created_at as \"created_at!\", updated_at as \"updated_at!\"\n            ",
