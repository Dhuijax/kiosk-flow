{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT \n                pi.id, \n                pi.product_id, \n                pi.ingredient_id, \n                pi.quantity,\n                pi.is_customizable,\n                i.name as ingredient_name,\n                i.unit\n            FROM product_ingredients pi\n            JOIN ingredients i ON pi.ingredient_id = i.id\n            WHERE pi.tenant_id = $1 AND pi.product_id = $2\n            ",
