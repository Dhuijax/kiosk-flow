  "query": "\n            SELECT id, tenant_id, title, content, level, start_date as \"start_date!\", end_date as \"end_date!\", created_at as \"created_at!\"\n            FROM announcements\n            WHERE start_date <= NOW() AND end_date >= NOW()\n            ORDER BY created_at DESC\n            ",
