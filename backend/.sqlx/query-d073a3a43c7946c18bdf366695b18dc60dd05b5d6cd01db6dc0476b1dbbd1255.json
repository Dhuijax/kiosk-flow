  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, tenant_id, name, unit, cost_price, is_active as \"is_active!\", created_at as \"created_at!\", updated_at as \"updated_at!\"\n            FROM ingredients\n            WHERE (name ILIKE $1 OR $1 = '%%')\n            ORDER BY created_at DESC\n            ",
