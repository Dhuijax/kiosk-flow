  "query": "\n            UPDATE floor_plans\n            SET \n                name = COALESCE($1, name),\n                layout_data = COALESCE($2, layout_data),\n                updated_at = NOW()\n            WHERE id = $3\n            RETURNING id, tenant_id, branch_id, name, layout_data, created_at as \"created_at!\", updated_at as \"updated_at!\"\n            ",
